# Copy to .env and adjust. See src/plugins/env.ts for defaults and validation.

# development | production | test
NODE_ENV=development

# HTTP listen address (defaults: localhost)
HOST=localhost

# Port as string (default: 8000)
PORT=8000

# CORS: empty or * = allow any origin. Otherwise comma-separated full origins
# (scheme + host + non-default port), e.g. http://localhost:3000,https://app.example.com
CORS_ORIGIN=
